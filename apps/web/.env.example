DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aarshjul"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-long-random-secret"
ADMIN_EMAILS="admin@example.com"
SYSTEM_ADMIN_EMAILS="sysadmin@example.com"
# Optional Azure AD group ids (comma-separated) that should receive system admin role automatically.
SYSTEM_ADMIN_GROUP_IDS=""
# Dedicated local system admin login (default shown below).
SYSTEM_ADMIN_LOCAL_USERNAME="sysadmin"
SYSTEM_ADMIN_LOCAL_PASSWORD="sysadmin"
SYSTEM_ADMIN_LOCAL_EMAIL="sysadmin@local"
SYSTEM_ADMIN_LOCAL_NAME="System Admin"

# Optional (required only for Azure AD SSO):
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Configure optional SMTP for reminder e-mails.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@your-domain.com"

# Secret required by /api/jobs/reminders/dispatch
REMINDER_JOB_SECRET="replace-with-job-secret"
