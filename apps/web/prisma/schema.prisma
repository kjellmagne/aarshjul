generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ShareTargetType {
  USER
  AAD_GROUP
}

enum ApiKeyScope {
  SYSTEM
  TENANT
}

enum WheelRole {
  VIEWER
  EDITOR
  OWNER
}

enum ScheduleCadence {
  NONE
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM_RRULE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum TenantRole {
  MEMBER
  ADMIN
}

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String?  @unique
  passwordHash    String?
  isAdmin         Boolean  @default(false)
  isSystemAdmin   Boolean  @default(false)
  emailVerified   DateTime?
  image           String?
  azureAdObjectId String?  @unique
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  ownedWheels        Wheel[]      @relation("WheelOwner")
  wheelUserShares    WheelShare[] @relation("WheelShareUser")
  wheelCreatedShares WheelShare[] @relation("WheelShareCreatedBy")
  activitiesCreated  Activity[]   @relation("ActivityCreator")
  tenantSettingsUpdated TenantSettings[]  @relation("TenantSettingsUpdatedBy")
  tenantMemberships     TenantMembership[]
  apiKeysCreated        ApiKey[]          @relation("ApiKeyCreatedBy")
}

model AzureGroup {
  id            String   @id @default(cuid())
  tenantGroupId String   @unique
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shares WheelShare[] @relation("WheelShareGroup")
}

model TenantSettings {
  id             String   @id @default("default")
  tenantName     String   @default("Organization")
  supportEmail   String?
  timezone       String   @default("Europe/Oslo")
  defaultLanguage String  @default("nb")
  allowLocalAuth Boolean  @default(true)
  allowAzureAuth Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  updatedById    String?

  updatedBy User? @relation("TenantSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  supportEmail    String?
  timezone        String   @default("Europe/Oslo")
  defaultLanguage String   @default("nb")
  allowLocalAuth  Boolean  @default(true)
  allowAzureAuth  Boolean  @default(true)
  azureTenantId   String?
  azureClientId   String?
  azureClientSecret String?
  smtpHost        String?
  smtpPort        Int?
  smtpSecure      Boolean  @default(false)
  smtpUser        String?
  smtpPass        String?
  smtpFrom        String?
  smtpReplyTo     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wheels      Wheel[]
  memberships TenantMembership[]
  apiKeys     ApiKey[]
}

model ApiKey {
  id         String      @id @default(cuid())
  scope      ApiKeyScope
  tenantId   String?
  name       String
  prefix     String      @unique
  secretHash String      @unique
  createdById String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("ApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([tenantId])
  @@index([createdById])
  @@index([revokedAt])
  @@index([expiresAt])
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  isDisabled Boolean   @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
  @@index([tenantId, isDisabled])
}

model Wheel {
  id             String   @id @default(cuid())
  title          String
  timezone       String   @default("Europe/Oslo")
  startDate      DateTime
  durationMonths Int      @default(12)
  config         Json?
  ownerId        String
  tenantId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner      User         @relation("WheelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tenant     Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  activities Activity[]
  shares     WheelShare[]

  @@index([ownerId])
  @@index([tenantId])
}

model WheelShare {
  id          String          @id @default(cuid())
  wheelId     String
  targetType  ShareTargetType
  role        WheelRole       @default(VIEWER)
  userId      String?
  groupId     String?
  createdById String
  createdAt   DateTime        @default(now())

  wheel     Wheel       @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  user      User?       @relation("WheelShareUser", fields: [userId], references: [id], onDelete: Cascade)
  group     AzureGroup? @relation("WheelShareGroup", fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User        @relation("WheelShareCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([wheelId])
  @@index([userId])
  @@index([groupId])
  @@unique([wheelId, targetType, userId])
  @@unique([wheelId, targetType, groupId])
}

model Activity {
  id          String   @id @default(cuid())
  wheelId     String
  ringId      String
  title       String
  description String?
  color       String
  startAt     DateTime
  endAt       DateTime
  tags        Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wheel     Wheel             @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  createdBy User?             @relation("ActivityCreator", fields: [createdById], references: [id], onDelete: SetNull)
  schedule  ActivitySchedule?
  reminders ActivityReminder[]

  @@index([wheelId])
  @@index([startAt, endAt])
}

model ActivitySchedule {
  id                     String          @id @default(cuid())
  activityId             String          @unique
  timezone               String          @default("Europe/Oslo")
  cadence                ScheduleCadence @default(ONCE)
  deadlineAt             DateTime?
  rrule                  String?
  reminderOffsetsMinutes Int[]           @default([])
  reminderEmails         String[]        @default([])
  isEnabled              Boolean         @default(true)
  nextDeadlineAt         DateTime?
  lastComputedAt         DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  reminders ActivityReminder[]

  @@index([nextDeadlineAt])
}

model ActivityReminder {
  id             String         @id @default(cuid())
  activityId     String
  scheduleId     String?
  recipientEmail String
  scheduledFor   DateTime
  offsetMinutes  Int
  status         ReminderStatus @default(PENDING)
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime       @default(now())

  activity Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  schedule ActivitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([status, scheduledFor])
  @@index([activityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
