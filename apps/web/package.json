{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3001",
    "dev:turbo": "next dev -p 3001",
    "dev:clean": "sh -c 'if lsof -ti tcp:3001 >/dev/null 2>&1; then echo \"Port 3001 er i bruk. Stopp dev-server først (Ctrl+C), og kjør så dev:clean igjen.\"; exit 1; fi; rm -rf .next && next dev --webpack -p 3001'",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@aarshjul/wheel-core": "file:../../packages/wheel-core",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "luxon": "^3.5.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.8.2"
  }
}
