# Copy to .env before running docker compose.

# App image to run. Local build example:
#   docker build -t aarshjul:local .
#   AARSHJUL_IMAGE=aarshjul:local
AARSHJUL_IMAGE=aarshjul:local

APP_PORT=3002
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=replace-with-long-random-secret

POSTGRES_DB=aarshjul
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ADMIN_EMAILS=admin@example.com
SYSTEM_ADMIN_EMAILS=sysadmin@example.com
SYSTEM_ADMIN_GROUP_IDS=

SYSTEM_ADMIN_LOCAL_USERNAME=sysadmin
SYSTEM_ADMIN_LOCAL_PASSWORD=sysadmin
SYSTEM_ADMIN_LOCAL_EMAIL=sysadmin@local
SYSTEM_ADMIN_LOCAL_NAME=System Admin

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

REMINDER_JOB_SECRET=replace-with-job-secret

# Set false if you want to run migrations outside container.
AUTO_DB_PUSH=true
DB_STARTUP_RETRIES=20
DB_STARTUP_WAIT_SECONDS=2
